# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-min-32-chars

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nextalk

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (Nodemailer - Gmail)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=noreply@nextalk.app

# UploadThing (Free file storage)
UPLOADTHING_SECRET=sk_live_your-uploadthing-secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# Admin
ADMIN_EMAILS=admin@example.com,admin2@example.com

# TOTP (2FA)
TOTP_ENCRYPTION_KEY=your-32-char-encryption-key-here!!
